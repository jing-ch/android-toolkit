<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="36dp">

        <!-- approach 1 -->
        <TextView
            android:id="@+id/title1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Part 1: Approach 1 - Handler"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnStart1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Start Primes (Handler)"
            app:layout_constraintTop_toBottomOf="@id/title1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnStop1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Stop"
            app:layout_constraintTop_toBottomOf="@id/btnStart1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvCurrent1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Current: 3"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/btnStop1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvPrime1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Latest prime: 0"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvCurrent1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />


        <!-- approach 2 -->
        <TextView
            android:id="@+id/title2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Part 1: Approach 2 - runOnUiThread"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/tvPrime1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnStart2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Start Primes (runOnUiThread)"
            app:layout_constraintTop_toBottomOf="@id/title2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnStop2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Stop"
            app:layout_constraintTop_toBottomOf="@id/btnStart2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvCurrent2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Current: 3"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/btnStop2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvPrime2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Latest prime: 0"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvCurrent2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <!-- part 2: greatest prime -->
        <TextView
            android:id="@+id/title3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Part 2:"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/tvPrime2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnFindGreatestPrime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Find Greatest Prime"
            app:layout_constraintTop_toBottomOf="@id/title3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            />

        <TextView
            android:id="@+id/tvGreatestPrime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Greatest prime: 0"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/btnFindGreatestPrime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp"
            />

        <!-- pacifier switch -->
        <TextView
            android:id="@+id/title4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Part 3:"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/tvGreatestPrime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <CheckBox
            android:id="@+id/cbPacifier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pacifier Switch"
            android:textSize="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/title4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
